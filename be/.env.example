# ╔═══════════════════════════════════════════════════════════╗
# ║                                                           ║
# ║          PREOONIC BACKEND - ENVIRONMENT CONFIG            ║
# ║              Copy this file to .env and fill              ║
# ║                                                           ║
# ║  🟢 Required: Bắt buộc phải có để chạy project           ║
# ║  🟡 Optional: Không bắt buộc, có thể để sau              ║
# ║  🔵 Future: Cho tính năng tương lai                      ║
# ║                                                           ║
# ╚═══════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════
# 🟢 REQUIRED - Cần thiết để chạy server
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
API_PREFIX=/api/v1

# ─────────────────────────────────────────────────────────
# Database - MongoDB (Bắt buộc)
# ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/preoonic
# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/preoonic?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────
# JWT Authentication (Bắt buộc - ⚠️ ĐỔI MẬT KHẨU MỚI!)
# ─────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET_KEY_IN_PRODUCTION
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_STRONG_SECRET_KEY
JWT_REFRESH_EXPIRE=30d

# Password Reset & Security
PASSWORD_RESET_EXPIRE=10
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=15

# ─────────────────────────────────────────────────────────
# CORS - Frontend URL (Bắt buộc)
# ─────────────────────────────────────────────────────────
# Production: https://<ten-frontend-tren-vercel>.vercel.app
FRONTEND_URL=http://localhost:3000

# Nếu cần cho preview deployment của Vercel hoặc nhiều URL nội bộ,
# thêm danh sách phân tách bằng dấu phẩy.
# FRONTEND_URLS=https://preview-1.vercel.app,https://preview-2.vercel.app


# ═══════════════════════════════════════════════════════════
# 🔵 FUTURE FEATURES - Dành cho các tính năng tương lai
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────
# 🔵 Email Service (SMTP)
# ─────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM_NAME=PreOnic Platform
# SMTP_FROM_EMAIL=noreply@preoonic.com

# ─────────────────────────────────────────────────────────
# 🔵 File Upload
# ─────────────────────────────────────────────────────────
# MAX_FILE_SIZE=5242880
# UPLOAD_PATH=./uploads
# ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/webp

# ─────────────────────────────────────────────────────────
# 🔵 Cloud Storage (AWS S3/Cloudinary)
# ─────────────────────────────────────────────────────────
# USE_CLOUD_STORAGE=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=ap-southeast-1

# ─────────────────────────────────────────────────────────
# 🔵 Redis Cache
# ─────────────────────────────────────────────────────────
# REDIS_ENABLED=false
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# CACHE_TTL=3600

# ─────────────────────────────────────────────────────────
# 🔵 Rate Limiting
# ─────────────────────────────────────────────────────────
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ─────────────────────────────────────────────────────────
# 🔵 Payment Gateways
# ─────────────────────────────────────────────────────────
# VNPAY_TMN_CODE=
# VNPAY_HASH_SECRET=
# VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return

# ─────────────────────────────────────────────────────────
# 🔵 External APIs
# ─────────────────────────────────────────────────────────
# GOOGLE_MAPS_API_KEY=
# WEATHER_API_KEY=

# ─────────────────────────────────────────────────────────
# 🔵 Social OAuth
# ─────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ─────────────────────────────────────────────────────────
# 🔵 Business Logic Settings
# ─────────────────────────────────────────────────────────
# MIN_CONTRACT_DURATION_DAYS=30
# MAX_CONTRACT_DURATION_DAYS=365
# CONTRACT_DEPOSIT_PERCENTAGE=20
# PRODUCT_APPROVAL_REQUIRED=false
# PLATFORM_COMMISSION_RATE=5
